// 14-agregacao.dart  
// Agregação e Composição

class Dependente {
  late String _nome;

  Dependente(String nome) {
    this._nome = nome;
  }
  
  // Getter para acesso ao nome
  String get nome => _nome;
  
  // Método toJson para serialização
  Map<String, dynamic> toJson() => {'nome': _nome};
}

class Funcionario {
  late String _nome;
  late List<Dependente> _dependentes;

  Funcionario(String nome, List<Dependente> dependentes) {
    this._nome = nome;
    this._dependentes = dependentes;
  }
  
  // Getters
  String get nome => _nome;
  List<Dependente> get dependentes => _dependentes;
  
  // Método toJson para serialização
  Map<String, dynamic> toJson() => {
    'nome': _nome,
    'dependentes': _dependentes.map((d) => d.toJson()).toList()
  };
}

class EquipeProjeto {
  late String _nomeProjeto;
  late List<Funcionario> _funcionarios;

  EquipeProjeto(String nomeprojeto, List<Funcionario> funcionarios) {
    _nomeProjeto = nomeprojeto;
    _funcionarios = funcionarios;
  }
  
  // Getters
  String get nomeProjeto => _nomeProjeto;
  List<Funcionario> get funcionarios => _funcionarios;
  
  // Método toJson para serialização JSON
  Map<String, dynamic> toJson() => {
    'projeto': _nomeProjeto,
    'funcionarios': _funcionarios.map((f) => f.toJson()).toList()
  };
  
  // Método para exibir no formato JSON bonito
  String toJsonPretty() => const JsonEncoder.withIndent('  ').convert(toJson());
}

void main() {
  print('🏢 === DEMONSTRAÇÃO AGREGação E COMPOSIÇÃO ===\n');
  
  // 1. Criar varios objetos Dependentes
  final dependentesJoao = [
    Dependente('Maria Silva'),
    Dependente('Pedro Silva'),
  ];
  
  final dependentesAna = [
    Dependente('Lucas Santos'),
  ];
  
  final dependentesCarlos = [
    Dependente('Ana Costa'),
    Dependente('João Costa'),
    Dependente('Mariana Costa'),
  ];
  
  print('✅ Dependentes criados: ${dependentesJoao.length + dependentesAna.length + dependentesCarlos.length}');
  
  // 2. Criar varios objetos Funcionario
  final joao = Funcionario('João Silva', dependentesJoao);
  final ana = Funcionario('Ana Santos', dependentesAna);
  final carlos = Funcionario('Carlos Costa', dependentesCarlos);
  
  print('✅ Funcionários criados: 3');
  
  // 3. Associar os Dependentes criados aos respectivos funcionarios
  // (já feito nos construtores acima)
  
  // 4. Criar uma lista de Funcionarios
  final listaFuncionarios = [joao, ana, carlos];
  
  print('✅ Lista de funcionários: ${listaFuncionarios.length}');
  print('');
  
  // 5. Criar um objeto Equipe Projeto
  final equipe = EquipeProjeto('Sistema de Gestão IoT', listaFuncionarios);
  
  print('🏗️  Equipe "${equipe.nomeProjeto}" criada!');
  print('👥 Total funcionários: ${equipe.funcionarios.length}');
  print('👨‍👩‍👧‍👦 Total dependentes: ${equipe.funcionarios.expand((f) => f.dependentes).length}');
  print('');
  
  // 6. Printar no formato JSON o objeto Equipe Projeto
  print('📊 === EQUIPE EM FORMATO JSON ===');
  print(equipe.toJsonPretty());
  print('');
  
  // Demonstração adicional: Acessar dados agregados
  print('🔍 === RESUMO DA EQUIPE ===');
  for (final funcionario in equipe.funcionarios) {
    print('👤 ${funcionario.nome}: ${funcionario.dependentes.length} dependente(s)');
    for (final dep in funcionario.dependentes) {
      print('   👶 ${dep.nome}');
    }
  }
}
